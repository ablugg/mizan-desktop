# Required
DATABASE_URL="file:./prisma/dev.db"

# Ollama — defaults shown, override if Ollama runs on a non-standard port
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Vector store path — defaults to ./data/vector-store
# VECTOR_DB_PATH=./data/vector-store

# Law sync: GitHub repo that hosts legal_chunks.lance.zip releases
# Attorneys use this to sync pre-ingested laws with one click
GITHUB_LAWS_REPO=ablugg/mizan-laws

# Admin panel (personal use only — do not share)
# Set MIZAN_ADMIN=true to enable /admin. Requires GITHUB_TOKEN with
# Contents: Write permission on GITHUB_LAWS_REPO to publish law releases.
# MIZAN_ADMIN=true
# GITHUB_TOKEN=github_pat_...
