{
  "name": "mizan",
  "version": "0.1.1",
  "private": true,
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "build:vectors": "tsx data/ingestion/build-vectors.ts",
    "download:ollama": "tsx scripts/download-ollama.ts",
    "electron:compile": "tsc --project electron/tsconfig.json",
    "electron:dev": "npm run electron:compile && concurrently \"next dev -p 3100\" \"wait-on http://localhost:3100 && NODE_ENV=development electron .\"",
    "electron:build": "npm run build && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public && npm run electron:compile && electron-builder --config electron.builder.yml"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@lancedb/lancedb": "^0.9.0",
    "@prisma/client": "^5.0.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "ai": "^4.0.0",
    "archiver": "^8.0.0",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.0",
    "docx": "^9.6.1",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.400.0",
    "mammoth": "^1.12.0",
    "next": "^16.1.6",
    "ollama": "^0.5.18",
    "pdf-parse": "^2.4.5",
    "pdf2json": "^4.0.2",
    "postcss": "^8.5.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.3.0",
    "unzipper": "^0.12.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/unzipper": "^0.10.11",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "prisma": "^5.0.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.0.0",
    "typescript": "^5",
    "wait-on": "^8.0.1"
  }
}
