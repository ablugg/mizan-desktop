generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String              @id @default(cuid())
  email            String              @unique @default("local@mizan.app")
  name             String?
  passwordHash     String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  conversations    Conversation[]
  attorneySessions AttorneySession[]
  toolUsage        AttorneyToolUsage[]
}

model Conversation {
  id        String     @id @default(cuid())
  title     String     @default("New Conversation")
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  documents Document[]
  pinned    Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
}

model Document {
  id               String       @id @default(cuid())
  conversationId   String
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId           String
  name             String
  mimeType         String
  size             Int
  content          String
  encryptedContent String?
  createdAt        DateTime     @default(now())

  @@index([conversationId])
  @@index([userId])
}

model Message {
  id               String       @id @default(cuid())
  conversationId   String
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role             String
  content          String
  encryptedContent String?
  citations        String?
  attachedFiles    String?
  createdAt        DateTime     @default(now())

  @@index([conversationId])
}

model AttorneySession {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool      String
  title     String
  data      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([userId, tool])
}

model AttorneyToolUsage {
  id     String       @id @default(cuid())
  userId String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool   String
  usedAt DateTime     @default(now())

  @@index([userId, tool])
  @@index([userId, usedAt])
}
